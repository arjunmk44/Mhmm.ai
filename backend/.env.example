# Local PostgreSQL (Docker)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=iki

# Application Database (Local Docker / Supabase)
# Required by Backend
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/iki

# Hosted PostgreSQL (Supabase) - Optional / Prod
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_DATABASE_URL=postgresql://postgres:<password>@db.your-project.supabase.co:5432/postgres

# Neo4j Graph DB - Required by AI/ML
NEO4J_URI=neo4j+s://<your-aura-db-id>.databases.neo4j.io
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password

# LLM APIs - Required by AI/ML
GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key

# Frontend API Target
VITE_API_BASE_URL=http://localhost:8000

# Backend Security & Scheduling
JWT_SECRET=your_jwt_secret_key_change_me
FAILURE_SCAN_INTERVAL_HOURS=6
MOCK_AI_ML=false
